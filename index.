<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Secret 💌</title>

<style>
body {
    margin: 0;
    overflow: hidden;
    font-family: 'Segoe UI', sans-serif;
    background: black;
    color: white;
    text-align: center;
}

/* Màn mở đầu */
#intro {
    position: absolute;
    width: 100%;
    height: 100%;
    background: black;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 24px;
    cursor: pointer;
}

/* Nội dung chính */
#main {
    display: none;
}

#message {
    position: absolute;
    top: 40%;
    width: 100%;
    font-size: 28px;
    font-weight: bold;
}

/* trái tim bay */
.heart {
    position: absolute;
    color: pink;
    font-size: 16px;
    animation: float 5s linear infinite;
}

@keyframes float {
    0% {transform: translateY(100vh); opacity:1;}
    100% {transform: translateY(-10vh); opacity:0;}
}

/* nút */
.btn {
    position: absolute;
    top: 65%;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    border: none;
    background: pink;
    color: black;
    font-size: 16px;
    border-radius: 20px;
    cursor: pointer;
}

/* hiệu ứng trái tim lớn */
canvas {
    position: absolute;
    top: 0;
    left: 0;
}
</style>
</head>

<body>

<!-- MỞ ĐẦU -->
<div id="intro">💌 Nhấn vào đây đi...</div>

<!-- NỘI DUNG -->
<div id="main">
    <canvas id="canvas"></canvas>
    <div id="message"></div>
    <button class="btn" onclick="reply()">Nhấn vào đây 💖</button>

    <audio id="music" loop>
        <source src="https://www.bensound.com/bensound-music/bensound-romantic.mp3">
    </audio>
</div>

<script>
// ====== TÙY CHỈNH ======
const crushName = "Trần Thành Đạt"; 
const text = `Tớ có điều này muốn nói với ${crushName}...\nChào mừng anh về nhà, anh đã làm rất tốt rồi nên thưởng thêm 1000 nụ hôn nhé💖`;

// ====== MỞ MÀN ======
document.getElementById("intro").onclick = function() {
    document.getElementById("intro").style.display = "none";
    document.getElementById("main").style.display = "block";
    document.getElementById("music").play();
    typeWriter();
    heartShape();
};

// ====== TEXT GÕ ======
let i = 0;
function typeWriter() {
    const msg = document.getElementById("message");
    if (i < text.length) {
        if (text.charAt(i) === "\n") msg.innerHTML += "<br>";
        else msg.innerHTML += text.charAt(i);
        i++;
        setTimeout(typeWriter, 50);
    }
}

// ====== TIM BAY ======
setInterval(() => {
    const h = document.createElement("div");
    h.className = "heart";
    h.innerHTML = "❤";
    h.style.left = Math.random()*100+"vw";
    document.body.appendChild(h);
    setTimeout(()=>h.remove(),5000);
},200);

// ====== VẼ TIM LỚN ======
function heartShape(){
    const canvas = document.getElementById("canvas");
    const ctx = canvas.getContext("2d");

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    let t = 0;

    function draw(){
        ctx.clearRect(0,0,canvas.width,canvas.height);
        for(let i=0;i<100;i++){
            let x = 16*Math.pow(Math.sin(t+i),3);
            let y = -(13*Math.cos(t+i)-5*Math.cos(2*(t+i))-2*Math.cos(3*(t+i))-Math.cos(4*(t+i)));

            ctx.fillStyle = "pink";
            ctx.fillRect(
                canvas.width/2 + x*10,
                canvas.height/2 + y*10,
                2,2
            );
        }
        t+=0.05;
        requestAnimationFrame(draw);
    }
    draw();
}

// ====== NÚT PHẢN HỒI ======
function reply(){
    alert("Nếu cậu cũng thích tớ... thì nói cho tớ biết nhé 💌");
}
</script>

</body>
</html>
